{
  "permissions": {
    "allow": [
      "Bash(pnpm lint)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build)",
      "Bash(pnpm exec:*)"
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules"
    ]
  },
  "sandbox": {
    "excludedCommands": [
      "pnpm"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/dispatch-on-write.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
